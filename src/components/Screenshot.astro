---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
	src: ImageMetadata;
	alt: string;
	caption?: string;
}

const { src, alt, caption } = Astro.props;
---

<figure class="screenshot my-8 overflow-hidden rounded-lg border border-border bg-bg-soft">
	<Image {src} {alt} class="block h-auto w-full" />
	{
		caption && (
			<figcaption class="border-t border-border px-4 py-3 font-mono text-2xs tracking-[0.16em] text-fg-subtle uppercase">
				{caption}
			</figcaption>
		)
	}
</figure>

<style is:global>
	.prose-case .screenshot img {
		margin: 0;
		border: 0;
		border-radius: 0;
	}
</style>
