---
import MobileNav from './MobileNav.svelte';
import ThemeToggle from './ThemeToggle.svelte';

const nav = [
	{ href: '/work', label: 'Work' },
	{ href: '/services', label: 'Services' },
	{ href: '/insights', label: 'Insights' },
	{ href: '/about', label: 'About' },
];

const path = Astro.url.pathname;
---

<header
	class="sticky top-0 z-40 border-b border-border bg-bg/80 backdrop-blur-md backdrop-saturate-150"
>
	<div
		class="mx-auto flex h-14 w-full max-w-page items-center justify-between gap-4 px-4 sm:gap-6 sm:px-8"
	>
		<a href="/" class="text-sm font-medium tracking-tight" aria-label="Roga Digital — home">
			Roga Digital
		</a>

		<!-- Desktop nav -->
		<nav aria-label="Primary" class="hidden items-center gap-1 md:flex">
			{
				nav.map((item) => {
					const active = path === item.href || path.startsWith(item.href + '/');
					return (
						<a
							href={item.href}
							class:list={[
								'rounded-sm px-3 py-1.5 text-sm transition-colors',
								active ? 'text-fg' : 'text-fg-muted hover:text-fg',
							]}
							aria-current={active ? 'page' : undefined}
						>
							{item.label}
						</a>
					);
				})
			}
			<span class="mx-1 h-4 w-px bg-border" aria-hidden="true"></span>
			<ThemeToggle client:idle />
			<a
				href="/contact"
				class="ml-1 inline-flex rounded-sm bg-fg px-3 py-1.5 text-sm font-medium text-bg transition-opacity hover:opacity-90"
			>
				Book a call
			</a>
		</nav>

		<!-- Mobile controls -->
		<div class="flex items-center gap-1 md:hidden">
			<ThemeToggle client:idle />
			<MobileNav items={nav} currentPath={path} client:load />
		</div>
	</div>
</header>
