---
import { ROLES, SITE_LOCATION } from '../../consts';
---

<section class="relative overflow-hidden border-b border-border">
	<div class="mx-auto w-full max-w-page px-6 sm:px-8">
		<div class="grid gap-12 pt-20 pb-24 sm:pt-28 sm:pb-32 lg:grid-cols-12 lg:gap-16">
			<!-- Left: positioning -->
			<div class="lg:col-span-7">
				<p
					class="flex items-center gap-3 font-mono text-2xs tracking-[0.18em] text-fg-subtle uppercase"
				>
					<span class="relative flex h-1.5 w-1.5">
						<span
							class="absolute inline-flex h-full w-full animate-ping rounded-full bg-positive opacity-75"
						></span>
						<span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-positive"></span>
					</span>
					Available for new work · {SITE_LOCATION}
				</p>

				<h1 class="mt-8 text-4xl font-medium tracking-tight text-balance sm:text-5xl lg:text-6xl">
					Software,
					<span class="text-fg-muted">end-to-end.</span>
				</h1>

				<p class="mt-6 max-w-2xl text-lg text-fg-muted text-pretty sm:text-xl">
					<span class="text-fg">Roga Digital</span> is a software studio that designs, ships, and maintains
					the tools businesses depend on. We build the internal tools, dashboards, integrations, and AI
					features your team actually uses — and stick around to keep them running.
				</p>

				<!-- Roles row -->
				<ul class="mt-10 flex flex-wrap gap-2 text-2xs" role="list" aria-label="Disciplines">
					{
						ROLES.map((role) => (
							<li class="rounded-full border border-border bg-bg-soft px-3 py-1 font-mono tracking-[0.12em] text-fg-muted uppercase">
								{role}
							</li>
						))
					}
				</ul>

				<div class="mt-10 flex flex-wrap items-center gap-3">
					<a
						href="/contact"
						class="inline-flex items-center gap-2 rounded-md bg-fg px-4 py-2.5 text-sm font-medium text-bg transition-opacity hover:opacity-90"
					>
						Book a call
						<svg
							width="14"
							height="14"
							viewBox="0 0 16 16"
							fill="none"
							stroke="currentColor"
							stroke-width="1.5"
							stroke-linecap="round"
							stroke-linejoin="round"
							aria-hidden="true"
						>
							<path d="M3 8h10M9 4l4 4-4 4"></path>
						</svg>
					</a>
					<a
						href="/work"
						class="inline-flex items-center gap-2 rounded-md border border-border-strong px-4 py-2.5 text-sm text-fg transition-colors hover:border-fg-subtle"
					>
						See selected work
					</a>
				</div>
			</div>

			<!-- Right: terminal / dashboard fragment -->
			<div class="lg:col-span-5">
				<div
					class="relative overflow-hidden rounded-lg border border-border bg-bg-soft shadow-[0_0_0_1px_rgba(91,103,255,0.04)]"
				>
					<div
						class="flex items-center justify-between border-b border-border px-4 py-2.5 font-mono text-2xs text-fg-subtle"
					>
						<span class="flex items-center gap-1.5" aria-hidden="true">
							<span class="h-2 w-2 rounded-full bg-negative"></span>
							<span class="h-2 w-2 rounded-full bg-warning"></span>
							<span class="h-2 w-2 rounded-full bg-positive"></span>
						</span>
						<span class="tracking-wider uppercase">~/projects/roga.dev</span>
					</div>
					<pre
						class="overflow-x-auto p-5 font-mono text-xs leading-relaxed text-fg-muted"><code><span class="text-fg-subtle">$</span> <span class="text-fg">rogadev</span> ship --quality production
<span class="text-fg-subtle">→</span> discovery    <span class="text-[var(--color-positive)]">✓</span> scope locked
<span class="text-fg-subtle">→</span> architecture <span class="text-[var(--color-positive)]">✓</span> services × 4
<span class="text-fg-subtle">→</span> build        <span class="text-[var(--color-positive)]">✓</span> 78,392 LOC
<span class="text-fg-subtle">→</span> deploy       <span class="text-[var(--color-positive)]">✓</span> cloud native
<span class="text-fg-subtle">→</span> handoff      <span class="text-[var(--color-positive)]">✓</span> docs · runbooks · monitors

<span class="text-[var(--color-accent)]">ships in weeks · still running years later</span></code></pre>
				</div>

				<!-- Stat strip -->
				<dl
					class="mt-4 grid grid-cols-1 gap-px overflow-hidden rounded-lg border border-border bg-border min-[420px]:grid-cols-3"
				>
					<div class="bg-bg-soft px-4 py-4">
						<dt class="font-mono text-2xs tracking-wider text-fg-subtle uppercase">Freelance</dt>
						<dd class="mt-1 text-xl font-medium text-fg">Since 2021</dd>
					</div>
					<div class="bg-bg-soft px-4 py-4">
						<dt class="font-mono text-2xs tracking-wider text-fg-subtle uppercase">Shipped</dt>
						<dd class="mt-1 text-xl font-medium text-fg">25+ projects</dd>
					</div>
					<div class="bg-bg-soft px-4 py-4">
						<dt class="font-mono text-2xs tracking-wider text-fg-subtle uppercase">Active</dt>
						<dd class="mt-1 text-xl font-medium text-fg">3 clients</dd>
					</div>
				</dl>
			</div>
		</div>
	</div>
</section>
