---
import { getCollection } from 'astro:content';
import Section from '../Section.astro';
import ClientLogos from './ClientLogos.astro';

const work = (await getCollection('work'))
	.filter((entry) => entry.data.featured && entry.data.status !== 'draft')
	.toSorted((a, b) => a.data.order - b.data.order);
---

<Section
	id="work"
	eyebrow="Selected work"
	heading="Software that's still running."
	dek="Real projects, real outcomes. Each shipped end-to-end, well maintained, and still running in production today."
>
	<div class="mx-auto w-full max-w-page">
		<ClientLogos />
		<ul
			class="grid grid-cols-1 gap-px overflow-hidden border-y border-border bg-border lg:grid-cols-2"
			role="list"
		>
			{
				work.map((w) => (
					<li class="group bg-bg transition-colors hover:bg-bg-soft">
						<a
							href={`/work/${w.id}/`}
							class="flex h-full flex-col gap-6 p-6 sm:p-8"
							aria-label={`${w.data.client} — ${w.data.headline}`}
						>
							<div class="flex items-center justify-between gap-4 font-mono text-2xs tracking-[0.18em] text-fg-subtle uppercase">
								<span>
									{w.data.id} · {w.data.industry}
								</span>
								<span class="text-fg-subtle transition-colors group-hover:text-fg">
									<span class="hidden sm:inline">Read case study&nbsp;</span>→
								</span>
							</div>

							<div>
								<p class="text-2xs font-mono tracking-[0.16em] text-[var(--color-accent)] uppercase">
									{w.data.client}
								</p>
								<h3 class="mt-3 text-2xl font-medium tracking-tight text-balance text-fg sm:text-3xl">
									{w.data.headline}
								</h3>
								<p class="mt-3 max-w-xl text-sm text-fg-muted">{w.data.outcome}</p>
							</div>

							<ul class="mt-auto flex flex-wrap gap-1.5 font-mono text-2xs" role="list">
								{w.data.tags.map((t) => (
									<li class="rounded-sm border border-border px-2 py-0.5 text-fg-muted">{t}</li>
								))}
							</ul>
						</a>
					</li>
				))
			}
		</ul>

		<div class="mt-12 px-6 sm:px-8">
			<a
				href="/work"
				class="inline-flex items-center gap-2 font-mono text-xs tracking-[0.16em] text-fg-muted uppercase transition-colors hover:text-fg"
			>
				All work
				<svg
					width="12"
					height="12"
					viewBox="0 0 16 16"
					fill="none"
					stroke="currentColor"
					stroke-width="1.5"
					stroke-linecap="round"
					stroke-linejoin="round"
					aria-hidden="true"
				>
					<path d="M3 8h10M9 4l4 4-4 4"></path>
				</svg>
			</a>
		</div>
	</div>
</Section>
