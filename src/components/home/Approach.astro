---
import Section from '../Section.astro';

const principles = [
	{
		num: '01',
		heading: 'Scope first, code second.',
		body: 'Most software fails before the first commit — wrong problem, fuzzy spec, scope that balloons. We start from what your business needs to change, work back to the smallest thing that gets there, and tell you what not to build.',
	},
	{
		num: '02',
		heading: 'You see it working, early.',
		body: 'No months of silence and a big reveal at the end. We ship in small, working pieces you can click through and react to — so what gets built is what you actually need, with no surprises when it lands.',
	},
	{
		num: '03',
		heading: 'Built to outlast the launch.',
		body: 'Launch is the start, not the finish line. Every project ships with documentation, runbooks, and monitoring — software your team can actually run. And we stay on to fix, extend, and maintain it for as long as you want us.',
	},
];
---

<Section
	id="approach"
	eyebrow="How It Works"
	heading="Before, during, and long after launch."
	dek="Great software comes down to three things: building what your business actually needs, keeping you in the loop the whole way, and standing behind it long after launch. That's how we work — start to finish, and well past it."
>
	<div class="mx-auto w-full max-w-page px-6 sm:px-8">
		<ol
			class="grid gap-px overflow-hidden rounded-lg border border-border bg-border lg:grid-cols-3"
		>
			{
				principles.map((p) => (
					<li class="flex flex-col gap-4 bg-bg p-8">
						<span class="font-mono text-2xs tracking-[0.18em] text-[var(--color-accent)] uppercase">
							{p.num}
						</span>
						<h3 class="text-xl font-medium tracking-tight text-balance text-fg">{p.heading}</h3>
						<p class="text-sm text-fg-muted text-pretty">{p.body}</p>
					</li>
				))
			}
		</ol>
	</div>
</Section>
