<section class="border-t border-border bg-bg-soft">
	<div class="mx-auto w-full max-w-page px-6 py-24 sm:px-8 sm:py-32">
		<div class="grid gap-10 lg:grid-cols-12 lg:items-end">
			<div class="lg:col-span-8">
				<p class="font-mono text-2xs tracking-[0.18em] text-fg-subtle uppercase">
					Let's build something
				</p>
				<h2 class="mt-4 text-4xl font-medium tracking-tight text-balance sm:text-5xl">
					Got a thing your team needs to be running on?
				</h2>
				<p class="mt-5 max-w-2xl text-lg text-fg-muted text-pretty">
					Internal tool, dashboard, integration, AI feature — or you're not sure yet what shape the
					answer takes. Either way, the first call is a free 30 minutes to figure out whether I'm
					the right fit.
				</p>
			</div>
			<div class="flex flex-wrap items-center gap-3 lg:col-span-4 lg:justify-end">
				<a
					href="/contact"
					class="inline-flex items-center gap-2 rounded-md bg-fg px-5 py-3 text-sm font-medium text-bg transition-opacity hover:opacity-90"
				>
					Book a call
					<svg
						width="14"
						height="14"
						viewBox="0 0 16 16"
						fill="none"
						stroke="currentColor"
						stroke-width="1.5"
						stroke-linecap="round"
						stroke-linejoin="round"
						aria-hidden="true"
					>
						<path d="M3 8h10M9 4l4 4-4 4"></path>
					</svg>
				</a>
			</div>
		</div>
	</div>
</section>
