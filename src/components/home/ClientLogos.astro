---
import { Image } from 'astro:assets';
import TelusLogo from '../../assets/clients/telus.svg';
import carevoLogo from '../../assets/clients/carevo.webp';
import grannyGoGoLogo from '../../assets/clients/granny-go-go.png';
import mossawayLogo from '../../assets/clients/mossaway.png';
import paoloLogo from '../../assets/clients/serres-de-paolo.png';
import viuLogo from '../../assets/clients/viu.png';
---

<div class="px-6 pb-6 sm:px-8 sm:pb-8">
	<p class="font-mono text-2xs tracking-[0.18em] text-fg-subtle uppercase">Worked with</p>
</div>

<div
	class="marquee mb-12 sm:mb-16"
	role="region"
	aria-label="Past clients — drag to scrub"
	tabindex="0"
	data-marquee
>
	<div class="marquee-track" data-marquee-track>
		<!-- Set A: announced to assistive tech -->
		<div class="marquee-item">
			<Image src={carevoLogo} alt="CarEvo" class="client-logo h-10 w-auto sm:h-12" />
		</div>
		<div class="marquee-item">
			<TelusLogo class="client-logo h-7 w-auto sm:h-8" aria-label="TELUS" role="img" />
		</div>
		<div class="marquee-item">
			<Image
				src={viuLogo}
				alt="Vancouver Island University"
				class="client-logo h-12 w-auto sm:h-14"
			/>
		</div>
		<div class="marquee-item">
			<Image src={paoloLogo} alt="Les Serres de Paolo" class="client-logo h-12 w-auto sm:h-14" />
		</div>
		<div class="marquee-item">
			<Image src={mossawayLogo} alt="MossAway" class="client-logo h-12 w-auto sm:h-14" />
		</div>
		<div class="marquee-item">
			<Image src={grannyGoGoLogo} alt="Granny Go Go" class="client-logo h-6 w-auto sm:h-7" />
		</div>

		<!-- Set B: visual duplicate for seamless loop, hidden from AT -->
		<div class="marquee-item" aria-hidden="true">
			<Image src={carevoLogo} alt="" class="client-logo h-10 w-auto sm:h-12" loading="lazy" />
		</div>
		<div class="marquee-item" aria-hidden="true">
			<TelusLogo class="client-logo h-7 w-auto sm:h-8" role="presentation" />
		</div>
		<div class="marquee-item" aria-hidden="true">
			<Image src={viuLogo} alt="" class="client-logo h-12 w-auto sm:h-14" loading="lazy" />
		</div>
		<div class="marquee-item" aria-hidden="true">
			<Image src={paoloLogo} alt="" class="client-logo h-12 w-auto sm:h-14" loading="lazy" />
		</div>
		<div class="marquee-item" aria-hidden="true">
			<Image src={mossawayLogo} alt="" class="client-logo h-12 w-auto sm:h-14" loading="lazy" />
		</div>
		<div class="marquee-item" aria-hidden="true">
			<Image src={grannyGoGoLogo} alt="" class="client-logo h-6 w-auto sm:h-7" loading="lazy" />
		</div>
	</div>
</div>

<style>
	.marquee {
		overflow-x: auto;
		overflow-y: hidden;
		cursor: grab;
		scrollbar-width: none;
		-ms-overflow-style: none;
		overscroll-behavior-x: contain;
		-webkit-mask-image: linear-gradient(
			to right,
			transparent,
			black 4rem,
			black calc(100% - 4rem),
			transparent
		);
		mask-image: linear-gradient(
			to right,
			transparent,
			black 4rem,
			black calc(100% - 4rem),
			transparent
		);
	}
	.marquee::-webkit-scrollbar {
		display: none;
	}
	.marquee.is-dragging {
		cursor: grabbing;
	}
	.marquee.is-dragging :global(*) {
		user-select: none;
		pointer-events: none;
	}
	.marquee:focus-visible {
		outline: 2px solid var(--color-fg, currentColor);
		outline-offset: 4px;
		border-radius: 4px;
	}
	.marquee-track {
		display: flex;
		align-items: center;
		width: max-content;
		gap: 3.5rem;
	}
	@media (min-width: 640px) {
		.marquee-track {
			gap: 5rem;
		}
	}
	.marquee-item {
		flex: 0 0 auto;
	}
	/* :global() escape so the filter reaches into <Image>/<TelusLogo> child components */
	:global(.client-logo) {
		filter: brightness(0) invert(1);
		opacity: 0.7;
	}
	:global(html.light .client-logo) {
		filter: brightness(0);
	}
	@media (prefers-reduced-motion: reduce) {
		.marquee {
			overflow: visible;
			cursor: auto;
			-webkit-mask-image: none;
			mask-image: none;
			padding-inline: 1.5rem;
		}
		.marquee-track {
			flex-wrap: wrap;
			width: 100%;
			gap: 2.5rem;
		}
		.marquee-item[aria-hidden='true'] {
			display: none;
		}
	}
</style>

<script>
	const SPEED = 30; // px/s autoplay

	function setup(container: HTMLElement) {
		if (container.dataset.marqueeReady) return;
		container.dataset.marqueeReady = '1';

		const track = container.querySelector<HTMLElement>('[data-marquee-track]');
		if (!track) return;

		const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

		let rafId = 0;
		let lastTime = 0;
		let hovering = false;
		let focused = false;
		let dragging = false;
		let touchActive = false;
		let dragStartX = 0;
		let dragStartScroll = 0;
		let activePointer: number | null = null;
		let touchResumeTimer = 0;

		const half = () => track.scrollWidth / 2;

		function wrapForward() {
			const h = half();
			if (h > 0 && container.scrollLeft >= h) container.scrollLeft -= h;
		}

		function wrapBoth() {
			const h = half();
			if (h <= 0) return;
			if (container.scrollLeft >= h) container.scrollLeft -= h;
			else if (container.scrollLeft < 0) container.scrollLeft += h;
		}

		const isPaused = () =>
			hovering || focused || dragging || touchActive || reducedMotion.matches;

		function tick(now: number) {
			if (!lastTime) lastTime = now;
			const dt = (now - lastTime) / 1000;
			lastTime = now;
			if (!isPaused()) {
				container.scrollLeft += SPEED * dt;
				wrapForward();
			}
			rafId = requestAnimationFrame(tick);
		}

		function start() {
			if (rafId) cancelAnimationFrame(rafId);
			lastTime = 0;
			rafId = requestAnimationFrame(tick);
		}

		function stop() {
			if (rafId) cancelAnimationFrame(rafId);
			rafId = 0;
		}

		container.addEventListener('mouseenter', () => {
			hovering = true;
		});
		container.addEventListener('mouseleave', () => {
			hovering = false;
		});
		container.addEventListener('focusin', () => {
			focused = true;
		});
		container.addEventListener('focusout', () => {
			focused = false;
		});

		container.addEventListener('pointerdown', (e) => {
			if (reducedMotion.matches) return;
			if (e.pointerType === 'mouse') {
				dragging = true;
				activePointer = e.pointerId;
				dragStartX = e.clientX;
				dragStartScroll = container.scrollLeft;
				container.classList.add('is-dragging');
				try {
					container.setPointerCapture(e.pointerId);
				} catch {}
				e.preventDefault();
			} else {
				touchActive = true;
				if (touchResumeTimer) {
					window.clearTimeout(touchResumeTimer);
					touchResumeTimer = 0;
				}
			}
		});

		container.addEventListener('pointermove', (e) => {
			if (!dragging || e.pointerId !== activePointer) return;
			const delta = e.clientX - dragStartX;
			container.scrollLeft = dragStartScroll - delta;
			wrapBoth();
			// Re-anchor so subsequent moves stay continuous after a wrap.
			dragStartX = e.clientX;
			dragStartScroll = container.scrollLeft;
		});

		function endPointer(e: PointerEvent) {
			if (e.pointerType === 'mouse') {
				if (!dragging) return;
				dragging = false;
				container.classList.remove('is-dragging');
				try {
					container.releasePointerCapture(e.pointerId);
				} catch {}
				activePointer = null;
			} else {
				// Let momentum settle before resuming autoplay.
				touchResumeTimer = window.setTimeout(() => {
					touchActive = false;
					touchResumeTimer = 0;
				}, 600);
			}
		}
		container.addEventListener('pointerup', endPointer);
		container.addEventListener('pointercancel', endPointer);

		container.addEventListener(
			'scroll',
			() => {
				wrapForward();
			},
			{ passive: true }
		);

		reducedMotion.addEventListener('change', () => {
			if (reducedMotion.matches) stop();
			else start();
		});

		if (!reducedMotion.matches) start();
	}

	function init() {
		document.querySelectorAll<HTMLElement>('[data-marquee]').forEach(setup);
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', init, { once: true });
	} else {
		init();
	}
</script>
