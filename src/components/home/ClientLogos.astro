---
import { Image } from 'astro:assets';
import TelusLogo from '../../assets/clients/telus.svg';
import carevoLogo from '../../assets/clients/carevo.webp';
import grannyGoGoLogo from '../../assets/clients/granny-go-go.png';
import mossawayLogo from '../../assets/clients/mossaway.png';
import paoloLogo from '../../assets/clients/serres-de-paolo.png';
import viuLogo from '../../assets/clients/viu.png';
import Marquee from '../Marquee.astro';

const logos = [
	{ type: 'telus' as const, alt: 'TELUS', class: 'h-7 w-auto sm:h-8' },
	{ type: 'image' as const, src: carevoLogo, alt: 'CarEvo', class: 'h-10 w-auto sm:h-12' },
	{
		type: 'image' as const,
		src: viuLogo,
		alt: 'Vancouver Island University',
		class: 'h-12 w-auto sm:h-14',
	},
	{
		type: 'image' as const,
		src: paoloLogo,
		alt: 'Les Serres de Paolo',
		class: 'h-12 w-auto sm:h-14',
	},
	{
		type: 'image' as const,
		src: mossawayLogo,
		alt: 'MossAway',
		class: 'h-12 w-auto sm:h-14',
	},
	{
		type: 'image' as const,
		src: grannyGoGoLogo,
		alt: 'Granny Go Go',
		class: 'h-6 w-auto sm:h-7',
	},
];

const COPIES = [0, 1, 2, 3, 4] as const;
const ANNOUNCED_COPY = 2;
---

<div class="px-6 pb-6 sm:px-8 sm:pb-8">
	<p class="font-mono text-2xs tracking-[0.18em] text-fg-subtle uppercase">Selected clients</p>
</div>

<Marquee
	ariaLabel="Past clients — drag to scrub"
	direction="forward"
	copies={COPIES.length}
	role="region"
	class="client-logos"
	trackClass="client-logos-track"
>
	{
		COPIES.flatMap((copy) =>
			logos.map((logo) => {
				const announced = copy === ANNOUNCED_COPY;
				return (
					<div class="marquee-item" aria-hidden={announced ? undefined : 'true'}>
						{logo.type === 'telus' ? (
							<TelusLogo
								class={`client-logo ${logo.class}`}
								aria-label={announced ? logo.alt : undefined}
								role={announced ? 'img' : 'presentation'}
							/>
						) : (
							<Image
								src={logo.src}
								alt={announced ? logo.alt : ''}
								loading="eager"
								class={`client-logo ${logo.class}`}
							/>
						)}
					</div>
				);
			}),
		)
	}
</Marquee>

<style is:global>
	/* Consumer-specific styles must be global: the .client-logos and
	   .client-logos-track elements are rendered by the Marquee component, so
	   they don't carry this file's scoped data-cid attribute. */
	.client-logos-track {
		gap: 3.5rem;
	}
	@media (min-width: 640px) {
		.client-logos-track {
			gap: 5rem;
		}
	}
	.client-logo {
		filter: brightness(0) invert(1);
		opacity: 0.7;
	}
	html.light .client-logo {
		filter: brightness(0);
	}
	/* Override Marquee primitive's xl static behavior — keep logos scrolling on desktop. */
	@media (min-width: 1280px) {
		.client-logos {
			overflow-x: auto;
			cursor: grab;
			-webkit-mask-image: linear-gradient(
				to right,
				transparent,
				black 4rem,
				black calc(100% - 4rem),
				transparent
			);
			mask-image: linear-gradient(
				to right,
				transparent,
				black 4rem,
				black calc(100% - 4rem),
				transparent
			);
		}
		.client-logos .marquee-item[aria-hidden='true'] {
			display: block;
		}
	}
	@media (prefers-reduced-motion: reduce) {
		.client-logos {
			padding-inline: 1.5rem;
		}
		.client-logos-track {
			flex-wrap: wrap;
			width: 100%;
			justify-content: center;
			gap: 2.5rem;
		}
	}
</style>
