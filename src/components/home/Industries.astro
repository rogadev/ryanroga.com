---
import { INDUSTRIES } from '../../consts';
import Marquee from '../Marquee.astro';

const items = [...INDUSTRIES];

const COPIES = [0, 1, 2, 3, 4] as const;
const ANNOUNCED_COPY = 2;
---

<Marquee
	ariaLabel="Industries served — drag to scrub"
	direction="reverse"
	copies={COPIES.length}
	rootTag="section"
	trackTag="ul"
	class="industries border-b border-border"
	trackClass="industries-track"
	staticAt="768px"
>
	{
		COPIES.flatMap((copy) =>
			items.map((industry, i) => {
				const announced = copy === ANNOUNCED_COPY;
				return (
					<li class="marquee-item industries-item" aria-hidden={announced ? undefined : 'true'}>
						<span>{industry}</span>
						{i < items.length - 1 && (
							<span aria-hidden="true" class="industry-sep">
								·
							</span>
						)}
					</li>
				);
			}),
		)
	}
</Marquee>

<style is:global>
	/* Consumer-specific styles must be global: the .industries and
	   .industries-track elements are rendered by the Marquee component, so
	   they don't carry this file's scoped data-cid attribute. */
	.industries {
		padding-block: 1.5rem;
	}
	@media (min-width: 640px) {
		.industries {
			padding-block: 2rem;
		}
	}
	.industries-track {
		gap: 0.75rem;
		margin: 0;
		padding: 0;
		list-style: none;
		font-size: var(--text-sm);
		line-height: var(--text-sm--line-height);
		color: var(--color-fg-muted);
	}
	@media (min-width: 640px) {
		.industries-track {
			gap: 1rem;
		}
	}
	.industries-item {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}
	@media (min-width: 640px) {
		.industries-item {
			gap: 1rem;
		}
	}
	.industry-sep {
		color: var(--color-fg-subtle);
	}
	/* Static layout: at md+ all industries fit on one row, so we drop the
	   marquee scroll/drag entirely, hide the duplicate copies, and lay the
	   single announced copy out as an evenly-spaced row capped to a sensible
	   reading width and centered on very wide viewports. */
	@media (min-width: 768px) {
		.industries {
			overflow: visible;
			cursor: auto;
			-webkit-mask-image: none;
			mask-image: none;
			padding-inline: 1.5rem;
		}
		.industries .marquee-item[aria-hidden='true'] {
			display: none;
		}
		.industries-track {
			width: 100%;
			max-width: 64rem;
			margin-inline: auto;
			justify-content: space-between;
			flex-wrap: wrap;
			row-gap: 0.5rem;
		}
	}
	@media (min-width: 1280px) {
		.industries {
			padding-inline: 2rem;
		}
	}
	@media (prefers-reduced-motion: reduce) {
		.industries {
			overflow: visible;
			cursor: auto;
			-webkit-mask-image: none;
			mask-image: none;
			padding-inline: 1.5rem;
		}
		.industries .marquee-item[aria-hidden='true'] {
			display: none;
		}
		.industries-track {
			width: 100%;
			max-width: 64rem;
			margin-inline: auto;
			justify-content: center;
			flex-wrap: wrap;
			row-gap: 0.5rem;
		}
	}
</style>
