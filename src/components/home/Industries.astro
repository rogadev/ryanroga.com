---
import { INDUSTRIES } from '../../consts';

const items = [...INDUSTRIES, '+ More'];

// Five identical copies — the middle copy is announced for assistive tech;
// the rest are decorative buffers that absorb native-touch momentum in either
// direction before it can hit the scroll boundary and clamp.
const COPIES = [0, 1, 2, 3, 4] as const;
const ANNOUNCED_COPY = 2;
---

<section
	aria-label="Industries served — drag to scrub"
	class="marquee border-b border-border"
	tabindex="0"
	data-marquee
	data-marquee-direction="reverse"
	data-marquee-copies={COPIES.length}
>
	<ul class="marquee-track" data-marquee-track role="list">
		{
			COPIES.flatMap((copy) =>
				items.map((industry, i) => {
					const announced = copy === ANNOUNCED_COPY;
					return (
						<li class="marquee-item" aria-hidden={announced ? undefined : 'true'}>
							<span>{industry}</span>
							{i < items.length - 1 && (
								<span aria-hidden="true" class="industry-sep">
									·
								</span>
							)}
						</li>
					);
				}),
			)
		}
	</ul>
</section>

<style>
	.marquee {
		overflow-x: auto;
		overflow-y: hidden;
		cursor: grab;
		scrollbar-width: none;
		-ms-overflow-style: none;
		overscroll-behavior-x: contain;
		padding-block: 1.5rem;
		-webkit-mask-image: linear-gradient(
			to right,
			transparent,
			black 4rem,
			black calc(100% - 4rem),
			transparent
		);
		mask-image: linear-gradient(
			to right,
			transparent,
			black 4rem,
			black calc(100% - 4rem),
			transparent
		);
	}
	@media (min-width: 640px) {
		.marquee {
			padding-block: 2rem;
		}
	}
	.marquee::-webkit-scrollbar {
		display: none;
	}
	.marquee.is-dragging {
		cursor: grabbing;
	}
	.marquee.is-dragging :global(*) {
		user-select: none;
		pointer-events: none;
	}
	.marquee-track {
		display: flex;
		align-items: center;
		width: max-content;
		gap: 0.75rem;
		margin: 0;
		padding: 0;
		list-style: none;
		font-size: var(--text-sm);
		line-height: var(--text-sm--line-height);
		color: var(--color-fg-muted);
	}
	@media (min-width: 640px) {
		.marquee-track {
			gap: 1rem;
		}
	}
	.marquee-item {
		flex: 0 0 auto;
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}
	@media (min-width: 640px) {
		.marquee-item {
			gap: 1rem;
		}
	}
	.industry-sep {
		color: var(--color-fg-subtle);
	}
	@media (min-width: 1280px) {
		.marquee {
			overflow: visible;
			cursor: auto;
			-webkit-mask-image: none;
			mask-image: none;
			padding-inline: 2rem;
		}
		.marquee-track {
			flex-wrap: wrap;
			width: 100%;
			justify-content: center;
			row-gap: 0.375rem;
		}
		.marquee-item[aria-hidden='true'] {
			display: none;
		}
	}
	@media (prefers-reduced-motion: reduce) {
		.marquee {
			overflow: visible;
			cursor: auto;
			-webkit-mask-image: none;
			mask-image: none;
			padding-inline: 1.5rem;
		}
		.marquee-track {
			flex-wrap: wrap;
			width: 100%;
			justify-content: center;
			row-gap: 0.375rem;
		}
		.marquee-item[aria-hidden='true'] {
			display: none;
		}
	}
</style>

<script>
	import '../../lib/marquee';
</script>
