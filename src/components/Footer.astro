---
import { BOOKING_URL, SITE_LOCATION, SOCIAL } from '../consts';

const today = new Date();

const cols = [
	{
		heading: 'Site',
		links: [
			{ href: '/work', label: 'Work' },
			{ href: '/services', label: 'Services' },
			{ href: '/insights', label: 'Writing' },
			{ href: '/about', label: 'About' },
			{ href: '/contact', label: 'Contact' },
		],
	},
	{
		heading: 'Elsewhere',
		links: [
			{ href: SOCIAL.github, label: 'GitHub', external: true },
			{ href: SOCIAL.linkedin, label: 'LinkedIn', external: true },
			{ href: '/rss.xml', label: 'RSS' },
		],
	},
	{
		heading: 'Legal',
		links: [
			{ href: '/privacy', label: 'Privacy' },
			{ href: '/terms', label: 'Terms' },
		],
	},
];
---

<footer class="border-t border-border bg-bg-soft">
	<div class="mx-auto w-full max-w-page px-6 py-16 sm:px-8 sm:py-20">
		<div class="grid gap-12 sm:grid-cols-12">
			<div class="sm:col-span-6">
				<a href="/" class="flex items-center gap-2 text-sm font-medium tracking-tight">
					<img
						src="/logo/android-chrome-512x512.png"
						alt=""
						width="24"
						height="24"
						class="h-6 w-6 rounded-sm"
						aria-hidden="true"
					/>
					Roga Digital
				</a>
				<p class="mt-4 max-w-sm text-sm text-fg-muted">
					A studio building business software end-to-end — full-stack development, systems
					architecture, product, and AI consulting.
				</p>
				<a
					href={BOOKING_URL}
					target="_blank"
					rel="noopener noreferrer"
					class="mt-6 inline-flex items-center gap-2 font-mono text-sm text-fg underline-offset-4 hover:underline"
				>
					Book a call
				</a>
			</div>

			{
				cols.map((col) => (
					<nav class="sm:col-span-2" aria-label={col.heading}>
						<p class="font-mono text-2xs tracking-[0.18em] text-fg-subtle uppercase">
							{col.heading}
						</p>
						<ul class="mt-4 space-y-2.5 text-sm">
							{col.links.map((l) => (
								<li>
									<a
										href={l.href}
										class="text-fg-muted transition-colors hover:text-fg"
										target={'external' in l && l.external ? '_blank' : undefined}
										rel={'external' in l && l.external ? 'noopener noreferrer' : undefined}
									>
										{l.label}
									</a>
								</li>
							))}
						</ul>
					</nav>
				))
			}
		</div>

		<div
			class="mt-16 flex flex-col items-start justify-between gap-3 border-t border-border pt-6 font-mono text-2xs tracking-wide text-fg-subtle uppercase sm:flex-row"
		>
			<p>© {today.getFullYear()} Roga Digital · {SITE_LOCATION}</p>
			<p>
				Built with Astro · Hosted on Vercel · <a
					href="/insights/why-this-stack/"
					class="transition-colors hover:text-fg">Learn why</a
				>
			</p>
		</div>
	</div>
</footer>
