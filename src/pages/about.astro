---
import Section from '../components/Section.astro';
import { SITE_LOCATION, SOCIAL, STUDIO_NAME } from '../consts';
import Base from '../layouts/Base.astro';

const title = `About · ${STUDIO_NAME}`;
const description = `${STUDIO_NAME} is a software studio run by Ryan Roga from BC, Canada. Internal tools, dashboards, integrations, and AI features for businesses — built end-to-end.`;

const facts = [
	{ label: 'Studio', value: STUDIO_NAME },
	{ label: 'Founder', value: 'Ryan Roga' },
	{ label: 'Based', value: SITE_LOCATION },
	{ label: 'Coding since', value: '2000' },
	{ label: 'Studio since', value: '2021' },
	{
		label: 'Education',
		value: 'Vancouver Island University · Web & Mobile Application Development',
	},
];

const stack = [
	'TypeScript',
	'SvelteKit · Svelte 5',
	'Astro',
	'Node.js · Express',
	'Python',
	'Postgres',
	'Vercel · Railway',
	'Tailwind CSS',
	'OpenAI · Anthropic',
	'Vitest',
	'Zod',
	'Prisma',
];

const principles = [
	{
		n: '01',
		h: 'Discovery before discovery decks.',
		b: "A free 30-minute call, then a written summary of what I think we should and shouldn't build. No deck, no padding. If we move forward, that summary becomes the starting scope.",
	},
	{
		n: '02',
		h: 'Weekly working previews.',
		b: "You see real, deployed progress every week. Feedback shapes the build, not a project manager's interpretation of it.",
	},
	{
		n: '03',
		h: 'Built to be inherited.',
		b: 'Every project ships with documentation, runbooks, and monitors. If you ever bring on internal devs, they should be able to read the code and ship the next feature without a call.',
	},
	{
		n: '04',
		h: 'Long after launch.',
		b: 'Software ages. A 30-day post-launch period is included by default. Many clients keep me on as a fractional partner — audits, gradual rebuilds, on-call for the things that matter.',
	},
];
---

<Base title={title} description={description}>
	<!-- Hero -->
	<section class="border-b border-border">
		<div class="mx-auto w-full max-w-page px-6 sm:px-8">
			<div class="grid gap-12 pt-20 pb-20 sm:pt-28 sm:pb-24 lg:grid-cols-12 lg:gap-16">
				<div class="lg:col-span-7">
					<p class="font-mono text-2xs tracking-[0.18em] text-fg-subtle uppercase">About</p>
					<h1 class="mt-6 text-4xl font-medium tracking-tight text-balance sm:text-5xl">
						A studio for the software businesses run on.
					</h1>
					<p class="mt-6 max-w-2xl text-lg text-fg-muted text-pretty sm:text-xl">
						{STUDIO_NAME} is a small studio in {SITE_LOCATION}, run by Ryan Roga. We design, build,
						and maintain the internal tools, dashboards, integrations, and AI features that
						companies depend on every day.
					</p>
					<div class="mt-8 flex flex-wrap items-center gap-3">
						<a
							href="/contact"
							class="inline-flex items-center gap-2 rounded-md bg-fg px-4 py-2.5 text-sm font-medium text-bg transition-opacity hover:opacity-90"
						>
							Start a conversation
							<svg
								width="14"
								height="14"
								viewBox="0 0 16 16"
								fill="none"
								stroke="currentColor"
								stroke-width="1.5"
								stroke-linecap="round"
								stroke-linejoin="round"
								aria-hidden="true"
							>
								<path d="M3 8h10M9 4l4 4-4 4"></path>
							</svg>
						</a>
						<a
							href="/resume"
							class="inline-flex items-center gap-2 rounded-md border border-border-strong px-4 py-2.5 text-sm text-fg transition-colors hover:border-fg-subtle"
						>
							Resume / CV
						</a>
					</div>
				</div>

				<div class="lg:col-span-5">
					<div class="overflow-hidden rounded-lg border border-border bg-bg-soft">
						<img
							src="/ryan.jpg"
							alt="Ryan Roga"
							width="640"
							height="640"
							class="aspect-square w-full object-cover"
							loading="eager"
							decoding="async"
						/>
					</div>
					<dl
						class="mt-4 grid grid-cols-1 gap-px overflow-hidden rounded-lg border border-border bg-border sm:grid-cols-2"
					>
						{
							facts.map((f) => (
								<div class="bg-bg-soft px-4 py-4">
									<dt class="font-mono text-2xs tracking-wider text-fg-subtle uppercase">
										{f.label}
									</dt>
									<dd class="mt-1 text-sm text-fg">{f.value}</dd>
								</div>
							))
						}
					</dl>
				</div>
			</div>
		</div>
	</section>

	<!-- Origin story -->
	<Section
		eyebrow="Origin"
		heading="A long road to a small studio."
		dek="Roga Digital is the product of twenty-five years writing code — and of the years I spent on the other side of the inbox running a business that depended on it."
	>
		<div class="mx-auto w-full max-w-page px-6 sm:px-8">
			<div class="space-y-6 max-w-3xl text-lg text-fg-muted text-pretty">
				<p>
					I wrote my first lines of code in 2000 — the era of view-source as education and curiosity
					as the only credential. Web applications, interactive electronic art, a stretch dabbling
					in embedded systems. Code was the thing I'd reach for whenever a problem looked like it
					could be automated.
				</p>
				<p>
					In 2017 I founded MossAway Services in Victoria, BC — a small home-services company — and
					put that history to work. The website and its CallRail + Zapier automation pipeline
					accounted for 100% of our leads, fully organic, for years. By 2022 the partner companies
					I'd built mobile quoting tools for were closing 30% more jobs.
				</p>
				<p>
					Around 2021 the side-skill became the thing I actually wanted to build. I enrolled in
					Vancouver Island University's Web &amp; Mobile Application Development program, graduated
					top of class in 2023, and spent my co-op at VIU itself building the Career Outlooks tool.
					Then I went full-time on what became {STUDIO_NAME}.
				</p>
				<p>
					The thread through all of it: I've sat at the desk where the software gets used. I know
					what it costs a small operation when a tool breaks at 5pm on a Friday. That's the
					perspective I bring to every project — not just "ship it," but "ship it so it earns its
					keep three years from now."
				</p>
			</div>
		</div>
	</Section>

	<!-- Principles -->
	<Section
		eyebrow="How I work"
		heading="A short list of strong defaults."
		dek="The same principles guide every engagement, from a two-week dashboard to a year-long platform build."
	>
		<div class="mx-auto w-full max-w-page px-6 sm:px-8">
			<ol
				class="grid gap-px overflow-hidden rounded-lg border border-border bg-border lg:grid-cols-2"
			>
				{
					principles.map((p) => (
						<li class="flex flex-col gap-3 bg-bg p-8">
							<span class="font-mono text-2xs tracking-[0.18em] text-[var(--color-accent)] uppercase">
								{p.n}
							</span>
							<h3 class="text-xl font-medium tracking-tight text-balance text-fg">{p.h}</h3>
							<p class="text-sm text-fg-muted text-pretty">{p.b}</p>
						</li>
					))
				}
			</ol>
		</div>
	</Section>

	<!-- Stack -->
	<Section
		eyebrow="Tools"
		heading="What I reach for."
		dek="Sharp opinions, weakly held. The stack changes when something genuinely better shows up — not on hype."
	>
		<div class="mx-auto w-full max-w-page px-6 sm:px-8">
			<ul class="flex flex-wrap gap-2 font-mono text-2xs" role="list">
				{
					stack.map((s) => (
						<li class="rounded-full border border-border bg-bg-soft px-3 py-1.5 tracking-[0.12em] text-fg-muted uppercase">
							{s}
						</li>
					))
				}
			</ul>
		</div>
	</Section>

	<!-- CTA -->
	<section class="border-t border-border bg-bg-soft">
		<div class="mx-auto w-full max-w-page px-6 py-20 sm:px-8 sm:py-24">
			<div class="grid gap-8 lg:grid-cols-12 lg:items-end">
				<div class="lg:col-span-8">
					<p class="font-mono text-2xs tracking-[0.18em] text-fg-subtle uppercase">Get in touch</p>
					<h2 class="mt-3 text-3xl font-medium tracking-tight text-balance sm:text-4xl">
						Have something you'd like {STUDIO_NAME} to build?
					</h2>
					<p class="mt-4 max-w-2xl text-lg text-fg-muted text-pretty">
						Tell me what you're working on. First call is a free 30 minutes — no sales pitch, just a
						candid read on whether I'm the right fit.
					</p>
				</div>
				<div class="flex flex-col gap-3 text-sm lg:col-span-4 lg:items-end">
					<a
						href="/contact"
						class="inline-flex items-center justify-center gap-2 rounded-md bg-fg px-5 py-3 font-medium text-bg transition-opacity hover:opacity-90"
					>
						Book a call
					</a>
					<div class="flex gap-4 font-mono text-2xs tracking-[0.16em] text-fg-subtle uppercase">
						<a href={SOCIAL.github} target="_blank" rel="noopener noreferrer" class="hover:text-fg"
							>GitHub</a
						>
						<a
							href={SOCIAL.linkedin}
							target="_blank"
							rel="noopener noreferrer"
							class="hover:text-fg">LinkedIn</a
						>
					</div>
				</div>
			</div>
		</div>
	</section>
</Base>
