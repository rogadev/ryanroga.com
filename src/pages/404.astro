---
import Base from '../layouts/Base.astro';

const title = 'Page not found · Roga Digital';
const description = `That page doesn't exist — or doesn't anymore. Try the work, the writing, or get in touch.`;

const links = [
	{
		label: 'Selected work',
		href: '/work',
		blurb: 'Case studies of shipped projects across telecom, healthcare, logistics, and more.',
	},
	{
		label: 'Writing',
		href: '/insights',
		blurb: 'Notes on building software, integrations, and AI features for businesses.',
	},
	{
		label: 'Services',
		href: '/services',
		blurb: 'How an engagement runs and what it costs.',
	},
	{
		label: 'Contact',
		href: '/contact',
		blurb: 'Book a free 30-minute call. Reply within 48 hours.',
	},
];
---

<Base title={title} description={description} noindex>
	<section class="border-b border-border">
		<div class="mx-auto w-full max-w-page px-6 sm:px-8">
			<div class="grid gap-12 pt-20 pb-16 sm:pt-28 sm:pb-20 lg:grid-cols-12 lg:gap-16">
				<div class="lg:col-span-7">
					<p class="font-mono text-2xs tracking-[0.18em] text-[var(--color-accent)] uppercase">
						404 · Not found
					</p>
					<h1 class="mt-6 text-4xl font-medium tracking-tight text-balance sm:text-5xl lg:text-6xl">
						That page isn't here.
						<span class="text-fg-muted">Maybe never was.</span>
					</h1>
					<p class="mt-6 max-w-2xl text-lg text-fg-muted text-pretty sm:text-xl">
						The link is broken, the page moved, or it never existed. Try one of the routes below —
						or head back to the
						<a href="/" class="text-fg underline-offset-4 hover:underline">home page</a>.
					</p>
					<div class="mt-8 flex flex-wrap items-center gap-3">
						<a
							href="/"
							class="inline-flex min-h-11 items-center gap-2 rounded-md bg-fg px-5 py-3 text-sm font-medium text-bg transition-opacity hover:opacity-90"
						>
							Go home
							<svg
								width="14"
								height="14"
								viewBox="0 0 16 16"
								fill="none"
								stroke="currentColor"
								stroke-width="1.5"
								stroke-linecap="round"
								stroke-linejoin="round"
								aria-hidden="true"
							>
								<path d="M3 8h10M9 4l4 4-4 4"></path>
							</svg>
						</a>
						<a
							href="/contact"
							class="inline-flex min-h-11 items-center gap-2 rounded-md border border-border px-5 py-3 text-sm font-medium text-fg transition-colors hover:bg-bg-soft"
						>
							Report a broken link
						</a>
					</div>
				</div>
				<div class="lg:col-span-5">
					<dl
						class="grid grid-cols-1 gap-px overflow-hidden rounded-lg border border-border bg-border sm:grid-cols-2"
					>
						<div class="bg-bg-soft px-4 py-4">
							<dt class="font-mono text-2xs tracking-wider text-fg-subtle uppercase">Status</dt>
							<dd class="mt-1 text-sm text-fg">404 · Not found</dd>
						</div>
						<div class="bg-bg-soft px-4 py-4">
							<dt class="font-mono text-2xs tracking-wider text-fg-subtle uppercase">
								Likely cause
							</dt>
							<dd class="mt-1 text-sm text-fg">Stale or mistyped URL</dd>
						</div>
					</dl>
				</div>
			</div>
		</div>
	</section>

	<section class="border-b border-border">
		<div class="mx-auto w-full max-w-page px-6 py-16 sm:px-8 sm:py-20">
			<p class="font-mono text-2xs tracking-[0.18em] text-fg-subtle uppercase">Try one of these</p>
			<ul
				class="mt-8 grid gap-px overflow-hidden rounded-lg border border-border bg-border sm:grid-cols-2"
				role="list"
			>
				{
					links.map((link) => (
						<li>
							<a
								href={link.href}
								class="group flex h-full min-h-11 flex-col gap-3 bg-bg p-6 transition-colors hover:bg-bg-soft sm:p-8"
							>
								<span class="inline-flex items-center gap-2 text-lg font-medium tracking-tight text-fg">
									{link.label}
									<svg
										width="14"
										height="14"
										viewBox="0 0 16 16"
										fill="none"
										stroke="currentColor"
										stroke-width="1.5"
										stroke-linecap="round"
										stroke-linejoin="round"
										aria-hidden="true"
										class="text-fg-subtle transition-transform group-hover:translate-x-0.5"
									>
										<path d="M3 8h10M9 4l4 4-4 4" />
									</svg>
								</span>
								<span class="text-sm text-fg-muted text-pretty">{link.blurb}</span>
							</a>
						</li>
					))
				}
			</ul>
		</div>
	</section>
</Base>
