---
import { getCollection } from 'astro:content';
import ClientLogos from '../../components/home/ClientLogos.astro';
import StatusIndicator from '../../components/StatusIndicator.astro';
import Base from '../../layouts/Base.astro';

const title = 'Work · Roga Digital';
const description =
	'Selected case studies from Roga Digital — operations platforms, internal tools, public sites, and AI features built end-to-end for businesses.';

const work = (await getCollection('work'))
	.filter((entry) => entry.data.status !== 'draft')
	.toSorted((a, b) => a.data.order - b.data.order);

const statusLabel = {
	live: 'Live',
	'in-development': 'In development',
	archived: 'Archived',
	draft: 'Draft',
};
---

<Base {title} {description}>
	<!-- Hero -->
	<section class="border-b border-border">
		<div class="mx-auto w-full max-w-page px-6 sm:px-8">
			<div class="grid gap-10 pt-20 sm:pt-28 lg:grid-cols-12 lg:gap-16">
				<div class="lg:col-span-8">
					<p class="font-mono text-2xs tracking-[0.18em] text-fg-subtle uppercase">Work</p>
					<h1 class="mt-6 text-4xl font-medium tracking-tight text-balance sm:text-5xl lg:text-6xl">
						Selected work,
						<span class="text-fg-muted">in production.</span>
					</h1>
					<p class="mt-6 max-w-2xl text-lg text-fg-muted text-pretty sm:text-xl">
						A selection from a longer list of client and studio projects, each shipped end-to-end —
						product, architecture, code, deploy, and ongoing maintenance — by the studio. Most are
						still running today.
					</p>
				</div>
				{
					/* Stats panel hidden temporarily — restore when numbers are confirmed.
					<div class="lg:col-span-4">
						<dl
							class="grid grid-cols-3 gap-px overflow-hidden rounded-lg border border-border bg-border"
						>
							<div class="bg-bg-soft px-4 py-4">
								<dt class="font-mono text-2xs tracking-wider text-fg-subtle uppercase">Shipped</dt>
								<dd class="mt-1 text-xl font-medium text-fg">{work.length}</dd>
							</div>
							<div class="bg-bg-soft px-4 py-4">
								<dt class="font-mono text-2xs tracking-wider text-fg-subtle uppercase">Maintained</dt>
								<dd class="mt-1 text-xl font-medium text-fg">
									{work.filter((w) => w.data.status === 'live').length}
								</dd>
							</div>
							<div class="bg-bg-soft px-4 py-4">
								<dt class="font-mono text-2xs tracking-wider text-fg-subtle uppercase">Clients</dt>
								<dd class="mt-1 text-xl font-medium text-fg">7+</dd>
							</div>
						</dl>
					</div>
					*/
				}
			</div>
		</div>
		<div class="mx-auto w-full max-w-page pt-12 pb-12 sm:pt-16 sm:pb-16">
			<ClientLogos />
		</div>
	</section>

	<!-- Work list -->
	<section class="border-b border-border">
		<div class="mx-auto w-full max-w-page">
			<ul class="divide-y divide-border" role="list">
				{
					work.map((w) => (
						<li>
							<a
								href={`/work/${w.id}/`}
								class="group block px-6 py-10 transition-colors hover:bg-bg-soft sm:px-8 sm:py-12"
								aria-label={`${w.data.client} — ${w.data.headline}`}
							>
								<div class="grid gap-6 lg:grid-cols-12 lg:gap-12">
									<div class="lg:col-span-3">
										<p class="font-mono text-2xs tracking-[0.18em] text-fg-subtle uppercase">
											{w.data.id}
										</p>
										<p class="mt-2 font-mono text-2xs tracking-[0.16em] text-[var(--color-accent)] uppercase">
											{w.data.client}
										</p>
										<p class="mt-3 font-mono text-2xs tracking-wider text-fg-subtle uppercase">
											{w.data.industry}
										</p>
										<p class="mt-4 inline-flex items-center gap-1.5 font-mono text-2xs tracking-[0.16em] text-fg-muted uppercase">
											<StatusIndicator status={w.data.status} />
											{statusLabel[w.data.status]}
										</p>
									</div>
									<div class="lg:col-span-9">
										<h2 class="text-2xl font-medium tracking-tight text-balance text-fg group-hover:underline group-hover:underline-offset-4 sm:text-3xl">
											{w.data.headline}
										</h2>
										<p class="mt-3 max-w-2xl text-fg-muted text-pretty">{w.data.outcome}</p>
										{w.data.highlight && (
											<p class="mt-3 max-w-2xl text-sm text-pretty text-fg-subtle italic">
												{w.data.highlight}
											</p>
										)}
										<ul class="mt-5 flex flex-wrap gap-1.5 font-mono text-2xs" role="list">
											{w.data.tags.map((t) => (
												<li class="rounded-sm border border-border px-2 py-0.5 text-fg-muted">
													{t}
												</li>
											))}
										</ul>
										<p class="mt-6 inline-flex items-center gap-1.5 font-mono text-2xs tracking-[0.18em] text-fg-subtle uppercase transition-colors group-hover:text-fg">
											Read case study →
										</p>
									</div>
								</div>
							</a>
						</li>
					))
				}
			</ul>
		</div>
	</section>

	<!-- End CTA -->
	<section class="bg-bg-soft">
		<div class="mx-auto w-full max-w-page px-6 py-20 sm:px-8 sm:py-24">
			<div class="grid gap-6 lg:grid-cols-12 lg:items-center">
				<div class="lg:col-span-8">
					<p class="font-mono text-2xs tracking-[0.18em] text-fg-subtle uppercase">
						Got a project like one of these?
					</p>
					<h2 class="mt-3 text-3xl font-medium tracking-tight text-balance sm:text-4xl">
						The first call is a free 30 minutes.
					</h2>
				</div>
				<div class="flex flex-wrap items-center gap-3 lg:col-span-4 lg:justify-end">
					<a
						href="/contact"
						class="inline-flex items-center gap-2 rounded-md bg-fg px-5 py-3 text-sm font-medium text-bg transition-opacity hover:opacity-90"
					>
						Book a call
					</a>
				</div>
			</div>
		</div>
	</section>
</Base>
