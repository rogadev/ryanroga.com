---
import Section from '../components/Section.astro';
import Base from '../layouts/Base.astro';

const title = 'Services · Roga Digital';
const description = 'What Roga Digital actually does — product strategy, systems architecture, full-stack development, AI integration, and the ongoing maintenance of the software businesses depend on.';

interface Service {
	id: string;
	number: string;
	title: string;
	lead: string;
	deliverables: string[];
	whenYouReachFor: string[];
	stack: string[];
	example?: { label: string; href: string };
}

const services: Service[] = [
	{
		id: 'product',
		number: '01',
		title: 'Product strategy & management',
		lead: "Most software fails before the first commit. Discovery, scope shaping, and roadmapping is where I figure out what to build — and, more importantly, what not to. I'll come in early, ask uncomfortable questions, and write the brief that we both work from.",
		deliverables: [
			'A written discovery summary you can share with stakeholders.',
			'Prioritized scope — what ships first, what defers, what we drop.',
			'Quarterly roadmap when the engagement is longer than a quarter.',
			'Light-touch user research where it changes a decision.',
		],
		whenYouReachFor: [
			'You have a vague but real problem and no spec.',
			'Stakeholders disagree on scope and you need a written read.',
			"A previous build didn't land and you're choosing what to do differently.",
		],
		stack: ['Discovery', 'Scoping', 'Roadmaps', 'User research'],
		example: { label: 'TechCentral · TELUS', href: '/work/telus-techcentral' },
	},
	{
		id: 'architecture',
		number: '02',
		title: 'Systems architecture',
		lead: 'Database design, API contracts, service boundaries, identity, role-based access control, audit logging. The decisions made in the first two weeks of a project are the ones you live with for years — they should be made deliberately, not by accident.',
		deliverables: [
			'Architecture diagram and a written rationale for each non-obvious choice.',
			'Data model with explicit role and permission semantics.',
			'API contracts (OpenAPI / GraphQL schema / typed RPC).',
			'Audit-log strategy and threat model when the data is sensitive.',
		],
		whenYouReachFor: [
			'Multi-tenant or multi-role product where access matters.',
			'Replacing a legacy system that grew organically.',
			"Pre-launch sanity check on someone else's design.",
		],
		stack: ['Postgres', 'REST · GraphQL', 'RBAC', 'Audit logs', 'Multi-tenant'],
		example: { label: 'TechCentral · TELUS', href: '/work/telus-techcentral' },
	},
	{
		id: 'fullstack',
		number: '03',
		title: 'Full-stack web development',
		lead: "Production web applications, end-to-end. Design through deploy. TypeScript by default, Svelte or Astro for the front, Node or Python for the back, Postgres for state. Choices made because they earn their keep — not because they're trending.",
		deliverables: [
			'A production web application — frontend, backend, database, deploy.',
			'CI/CD pipeline that catches regressions before they ship.',
			'A test suite scoped to what actually breaks (not coverage theatre).',
			'Documentation and runbooks aimed at the team that inherits the code.',
		],
		whenYouReachFor: [
			"You need a real web app and don't have a senior developer in-house.",
			'Existing build is slowing your team down and needs a clean rewrite.',
			'Greenfield product where you want one set of hands across the stack.',
		],
		stack: ['TypeScript', 'Svelte · Astro', 'Node · Python', 'Postgres', 'Vercel · Railway'],
		example: { label: 'E&EO · eaeo.ca', href: '/work/eaeo' },
	},
	{
		id: 'internal-tools',
		number: '04',
		title: 'Internal tools & dashboards',
		lead: 'The interfaces your team uses every day — operations panels, reporting dashboards, queue managers, content tooling. Fast, dense, kind to power users. Built to save time, not to look impressive in a pitch deck.',
		deliverables: [
			'A working tool deployed on day one of week one — no big-bang launch.',
			'Role-aware views (operator, supervisor, admin) from the same codebase.',
			'Filters, sorts, exports, bulk actions — the boring features that matter.',
			'Reports that go to email, Slack, or wherever the people who need them already are.',
		],
		whenYouReachFor: [
			'Your team is doing the same manual workaround in spreadsheets every week.',
			'Customer support is asking engineering for one-off database lookups.',
			"You're hiring more ops staff to cover what software should be doing.",
		],
		stack: ['Operational UI', 'Reporting', 'Bulk actions', 'Workflow tooling'],
		example: { label: 'TC Tools', href: '/work/telus-tc-tools' },
	},
	{
		id: 'ai',
		number: '05',
		title: 'AI integration & consulting',
		lead: "LLM features, retrieval, agents, evaluation. I'll help you figure out what AI actually changes for your product, where it earns its place, and where it doesn't. No hype, no vendor lock-in by default, no AI features for the sake of having AI features.",
		deliverables: [
			"Honest written assessment of where LLMs help and where they're a distraction.",
			'Prototype features (RAG, structured output, classification, agents) you can put in front of users.',
			'Evaluation pipeline — so you know if quality regresses with the next model swap.',
			'Provider strategy — when to pin to a vendor, when to stay portable.',
		],
		whenYouReachFor: [
			"Your team wants to ship AI features but you're not sure which ones.",
			"You've shipped an LLM feature and don't trust the output.",
			'Board asking about AI strategy and you want a real answer.',
		],
		stack: ['OpenAI · Anthropic', 'Vercel AI SDK', 'RAG', 'Eval', 'Agents'],
		example: { label: 'TC Tools', href: '/work/telus-tc-tools' },
	},
	{
		id: 'integrations',
		number: '06',
		title: 'Integrations & workflow automation',
		lead: 'Third-party APIs, ETL pipelines, webhooks, scheduled jobs, queues. The plumbing between systems that keeps a business running. Less glamorous than greenfield, often higher leverage.',
		deliverables: [
			'Reliable integrations that handle retries, idempotency, and rate limits.',
			'Background workers and scheduled jobs with monitoring.',
			'A clear, written map of every integration — what it does, what breaks if it stops.',
			'Alerting that pages the right person, not the whole team.',
		],
		whenYouReachFor: [
			'Data is being copy-pasted between two systems by a human, daily.',
			'A vendor migration is coming and you need a clean handoff.',
			'A scheduled job has been "mostly working" for years and finally broke.',
		],
		stack: ['REST · Webhooks', 'Stripe · QuickBooks · etc.', 'ETL', 'Background jobs', 'Cron'],
	},
	{
		id: 'maintenance',
		number: '07',
		title: 'Maintenance & ongoing partnership',
		lead: "Long-term support of software you already own — yours or someone else's. Audits, gradual rebuilds, on-call for the things that matter. Many engagements start as a project and become this.",
		deliverables: [
			'Codebase audit with prioritized findings (security, performance, fragility, debt).',
			'Monthly retainer covering bug fixes, small features, and operational support.',
			'Gradual modernization — incremental rewrites that never require a "big rewrite."',
			"On-call rotation that respects your team's actual coverage needs.",
		],
		whenYouReachFor: [
			"Software you depend on is older than its original developer's tenure.",
			'Original team has moved on and the docs disappeared with them.',
			"You want senior coverage but don't need a full-time hire.",
		],
		stack: ['Audits', 'Rebuilds', 'On-call', 'Documentation', 'Monitoring'],
	},
	{
		id: 'advisory',
		number: '08',
		title: 'Technical advisory',
		lead: "Architecture reviews, code review, hire decisions, vendor evaluations, second opinions. A pair of senior eyes when the stakes are high — and you don't need a full engagement, you need a read.",
		deliverables: [
			'Written architecture review with specific, prioritized recommendations.',
			'Code review of a feature, a refactor, or a whole repo.',
			'Hire decision support — interviewing for senior engineering or technical leadership.',
			'Vendor evaluations — "should we buy X or build it ourselves?"',
		],
		whenYouReachFor: [
			"You're about to commit to a big architectural decision and want a sanity check.",
			"You're hiring senior engineering and want a technical interviewer.",
			'A vendor pitch sounds too good and you want it stress-tested.',
		],
		stack: ['Code review', 'Architecture review', 'Hiring', 'Vendor evaluation'],
	},
];

const formats = [
	{
		n: 'Project',
		body: 'Scoped, fixed-outcome engagements. Discovery → build → handoff. Two weeks to several months. Best when the problem has clear edges.',
	},
	{
		n: 'Fractional',
		body: 'Recurring monthly retainer — typically 1–3 days per week. Best when the work is ongoing, evolving, or partially uncertain. Many project clients move here after launch.',
	},
	{
		n: 'Advisory',
		body: 'Short, focused, no-code engagements — architecture reviews, hire support, vendor evaluations, code reviews. Best when you need a read, not a build.',
	},
];
---

<Base {title} {description}>
	<!-- Hero -->
	<section class="border-b border-border">
		<div class="mx-auto w-full max-w-page px-6 sm:px-8">
			<div class="grid gap-12 pt-20 pb-16 sm:pt-28 sm:pb-20 lg:grid-cols-12 lg:gap-16">
				<div class="lg:col-span-8">
					<p class="font-mono text-2xs tracking-[0.18em] text-fg-subtle uppercase">Services</p>
					<h1 class="mt-6 text-4xl font-medium tracking-tight text-balance sm:text-5xl lg:text-6xl">
						What I work on,
						<span class="text-fg-muted">in detail.</span>
					</h1>
					<p class="mt-6 max-w-2xl text-lg text-fg-muted text-pretty sm:text-xl">
						Most engagements draw on two or three of these at once — discovery feeding architecture,
						architecture feeding code, code feeding the long maintenance life that follows. Below is
						the menu, expanded.
					</p>
				</div>
				<div class="lg:col-span-4">
					<a
						href="/contact"
						class="inline-flex items-center gap-2 rounded-md bg-fg px-5 py-3 text-sm font-medium text-bg transition-opacity hover:opacity-90"
					>
						Book a 30-min call
						<svg
							width="14"
							height="14"
							viewBox="0 0 16 16"
							fill="none"
							stroke="currentColor"
							stroke-width="1.5"
							stroke-linecap="round"
							stroke-linejoin="round"
							aria-hidden="true"
						>
							<path d="M3 8h10M9 4l4 4-4 4"></path>
						</svg>
					</a>
				</div>
			</div>
		</div>
	</section>

	<!-- TOC -->
	<section class="border-b border-border bg-bg-soft">
		<div class="mx-auto w-full max-w-page px-6 py-6 sm:px-8 sm:py-8">
			<nav aria-label="Services index">
				<p class="font-mono text-2xs tracking-[0.18em] text-fg-subtle uppercase">On this page</p>
				<ul
					class="mt-3 grid gap-x-6 gap-y-2 font-mono text-2xs tracking-[0.12em] uppercase sm:grid-cols-2 lg:grid-cols-4"
					role="list"
				>
					{
						services.map((s) => (
							<li>
								<a
									href={`#${s.id}`}
									class="inline-flex items-center gap-2 text-fg-muted transition-colors hover:text-fg"
								>
									<span class="text-fg-subtle">{s.number}</span>
									<span>{s.title}</span>
								</a>
							</li>
						))
					}
				</ul>
			</nav>
		</div>
	</section>

	<!-- Service sections -->
	{
		services.map((s, i) => (
			<section id={s.id} class:list={['scroll-mt-20', i !== 0 && 'border-t border-border']}>
				<div class="mx-auto w-full max-w-page px-6 py-20 sm:px-8 sm:py-24">
					<div class="grid gap-10 lg:grid-cols-12 lg:gap-12">
						<div class="lg:col-span-5">
							<p class="font-mono text-2xs tracking-[0.18em] text-[var(--color-accent)] uppercase">
								{s.number}
							</p>
							<h2 class="mt-4 text-3xl font-medium tracking-tight text-balance sm:text-4xl">
								{s.title}
							</h2>
							<p class="mt-5 text-lg text-fg-muted text-pretty">{s.lead}</p>
							<ul class="mt-6 flex flex-wrap gap-1.5 font-mono text-2xs" role="list">
								{s.stack.map((t) => (
									<li class="rounded-sm border border-border px-2 py-0.5 text-fg-muted">{t}</li>
								))}
							</ul>
							{s.example && (
								<a
									href={s.example.href}
									class="mt-6 inline-flex items-center gap-2 font-mono text-2xs tracking-[0.18em] text-fg-muted uppercase transition-colors hover:text-fg"
								>
									See in production · {s.example.label} →
								</a>
							)}
						</div>

						<div class="grid gap-10 lg:col-span-7 lg:grid-cols-2 lg:gap-8">
							<div>
								<p class="font-mono text-2xs tracking-[0.18em] text-fg-subtle uppercase">
									What you get
								</p>
								<ul class="mt-4 space-y-3 text-sm text-fg-muted" role="list">
									{s.deliverables.map((d) => (
										<li class="flex gap-2.5">
											<span
												class="mt-1.5 inline-block h-1 w-1 flex-shrink-0 rounded-full bg-[var(--color-accent)]"
												aria-hidden="true"
											/>
											<span class="text-pretty">{d}</span>
										</li>
									))}
								</ul>
							</div>
							<div>
								<p class="font-mono text-2xs tracking-[0.18em] text-fg-subtle uppercase">
									When you'd reach for this
								</p>
								<ul class="mt-4 space-y-3 text-sm text-fg-muted" role="list">
									{s.whenYouReachFor.map((c) => (
										<li class="flex gap-2.5">
											<span
												class="mt-1.5 inline-block h-1 w-1 flex-shrink-0 rounded-full bg-border-strong"
												aria-hidden="true"
											/>
											<span class="text-pretty">{c}</span>
										</li>
									))}
								</ul>
							</div>
						</div>
					</div>
				</div>
			</section>
		))
	}

	<!-- Engagement formats -->
	<Section
		eyebrow="Engagement formats"
		heading="Three ways we usually work."
		dek="Most projects fit one of these shapes. Many start as one and become another over time."
	>
		<div class="mx-auto w-full max-w-page px-6 sm:px-8">
			<ul
				class="grid gap-px overflow-hidden rounded-lg border border-border bg-border lg:grid-cols-3"
				role="list"
			>
				{
					formats.map((f) => (
						<li class="flex flex-col gap-3 bg-bg p-8">
							<p class="font-mono text-2xs tracking-[0.18em] text-[var(--color-accent)] uppercase">
								{f.n}
							</p>
							<p class="text-sm text-fg-muted text-pretty">{f.body}</p>
						</li>
					))
				}
			</ul>
		</div>
	</Section>

	<!-- End CTA -->
	<section class="border-t border-border bg-bg-soft">
		<div class="mx-auto w-full max-w-page px-6 py-20 sm:px-8 sm:py-24">
			<div class="grid gap-6 lg:grid-cols-12 lg:items-center">
				<div class="lg:col-span-8">
					<p class="font-mono text-2xs tracking-[0.18em] text-fg-subtle uppercase">
						Not sure which of these fits?
					</p>
					<h2 class="mt-3 text-3xl font-medium tracking-tight text-balance sm:text-4xl">
						That's what the first call is for.
					</h2>
					<p class="mt-4 max-w-2xl text-fg-muted text-pretty">
						Bring the problem, not the spec. We'll figure out together which of these (if any) is
						the right shape for what you're trying to do.
					</p>
				</div>
				<div class="flex flex-wrap items-center gap-3 lg:col-span-4 lg:justify-end">
					<a
						href="/contact"
						class="inline-flex items-center gap-2 rounded-md bg-fg px-5 py-3 text-sm font-medium text-bg transition-opacity hover:opacity-90"
					>
						Book a call
					</a>
				</div>
			</div>
		</div>
	</section>
</Base>
