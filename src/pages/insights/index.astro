---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const title = 'Insights · Roga Digital';
const description = 'Updates from Roga Digital — project write-ups, opinions on tooling, industry shifts, and what AI is changing about how business software gets built.';

const posts = (await getCollection('insights', ({ data }) => !data.draft)).toSorted(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// Group by year so older posts get a clear timeline anchor.
const byYear = posts.reduce<Record<string, typeof posts>>((acc, post) => {
	const year = post.data.pubDate.getFullYear().toString();
	if (!acc[year]) acc[year] = [];
	acc[year].push(post);
	return acc;
}, {});
const years = Object.keys(byYear).toSorted((a, b) => Number(b) - Number(a));

// Tag inventory for the tag bar.
const tagSet = new Set<string>();
posts.forEach((p) => p.data.tags.forEach((t) => tagSet.add(t)));
const tags = [...tagSet].toSorted();

const dateFormatter = new Intl.DateTimeFormat('en-US', {
	month: 'short',
	day: 'numeric',
});
---

<Base {title} {description}>
	<!-- Hero -->
	<section class="border-b border-border">
		<div class="mx-auto w-full max-w-page px-6 sm:px-8">
			<div class="grid gap-10 pt-20 pb-16 sm:pt-28 sm:pb-20 lg:grid-cols-12 lg:gap-16">
				<div class="lg:col-span-8">
					<p class="font-mono text-2xs tracking-[0.18em] text-fg-subtle uppercase">Insights</p>
					<h1 class="mt-6 text-4xl font-medium tracking-tight text-balance sm:text-5xl lg:text-6xl">
						Notes from
						<span class="text-fg-muted">the work.</span>
					</h1>
					<p class="mt-6 max-w-2xl text-lg text-fg-muted text-pretty sm:text-xl">
						Project write-ups, opinions on tooling, industry shifts, and pragmatic takes on what AI
						is changing about how business software gets built. Updates from Roga Digital, in full.
					</p>
				</div>
				<div class="lg:col-span-4">
					<dl
						class="grid grid-cols-2 gap-px overflow-hidden rounded-lg border border-border bg-border"
					>
						<div class="bg-bg-soft px-4 py-4">
							<dt class="font-mono text-2xs tracking-wider text-fg-subtle uppercase">Posts</dt>
							<dd class="mt-1 text-xl font-medium text-fg">{posts.length}</dd>
						</div>
						<div class="bg-bg-soft px-4 py-4">
							<dt class="font-mono text-2xs tracking-wider text-fg-subtle uppercase">Tags</dt>
							<dd class="mt-1 text-xl font-medium text-fg">{tags.length}</dd>
						</div>
						<div
							class="col-span-2 flex items-center justify-between gap-3 bg-bg-soft px-4 py-4 font-mono text-2xs tracking-[0.16em] uppercase"
						>
							<a
								href="/rss.xml"
								class="inline-flex items-center gap-2 text-fg transition-colors hover:text-fg-muted"
							>
								<svg
									width="12"
									height="12"
									viewBox="0 0 16 16"
									fill="none"
									stroke="currentColor"
									stroke-width="1.5"
									stroke-linecap="round"
									stroke-linejoin="round"
									aria-hidden="true"
								>
									<path d="M3 11a3 3 0 0 1 3 3M3 6a8 8 0 0 1 8 8"></path>
									<circle cx="3.5" cy="13.5" r="0.5" fill="currentColor"></circle>
								</svg>
								RSS
							</a>
							<span class="text-fg-subtle">
								{
									posts.length > 0 && posts[0]
										? `Latest · ${dateFormatter.format(posts[0].data.pubDate)}`
										: 'First post coming soon'
								}
							</span>
						</div>
					</dl>
				</div>
			</div>
		</div>
	</section>

	{
		tags.length > 0 && (
			<section class="border-b border-border bg-bg-soft">
				<div class="mx-auto w-full max-w-page px-6 py-6 sm:px-8">
					<div class="flex flex-wrap items-center gap-x-6 gap-y-3">
						<p class="font-mono text-2xs tracking-[0.18em] text-fg-subtle uppercase">Tags</p>
						<ul class="flex flex-wrap gap-2 font-mono text-2xs" role="list">
							{tags.map((t) => (
								<li>
									<a
										href={`#tag-${t}`}
										class="rounded-full border border-border bg-bg px-3 py-1 tracking-[0.12em] text-fg-muted uppercase transition-colors hover:border-fg-subtle hover:text-fg"
									>
										#{t}
									</a>
								</li>
							))}
						</ul>
					</div>
				</div>
			</section>
		)
	}

	{
		posts.length > 0 ? (
			<section class="border-b border-border">
				<div class="mx-auto w-full max-w-page">
					{years.map((year) => (
						<div class="border-b border-border last:border-b-0">
							<div class="grid grid-cols-1 lg:grid-cols-12">
								<div class="border-b border-border px-6 pt-10 pb-6 sm:px-8 lg:col-span-3 lg:border-r lg:border-b-0 lg:pt-12 lg:pb-12">
									<p class="sticky top-20 font-mono text-2xs tracking-[0.18em] text-fg-subtle uppercase">
										{year}
									</p>
								</div>
								<ul class="lg:col-span-9" role="list">
									{byYear[year]?.map((post) => (
										<li class="border-b border-border last:border-b-0">
											<a
												href={`/insights/${post.id}/`}
												class="group flex flex-col gap-3 px-6 py-8 transition-colors hover:bg-bg-soft sm:flex-row sm:items-baseline sm:gap-8 sm:px-8 sm:py-10"
											>
												<time
													datetime={post.data.pubDate.toISOString()}
													class="font-mono text-2xs tracking-[0.16em] whitespace-nowrap text-fg-subtle uppercase sm:w-24 sm:flex-shrink-0"
												>
													{dateFormatter.format(post.data.pubDate)}
												</time>
												<div class="flex-1">
													<h2 class="text-xl font-medium tracking-tight text-balance text-fg group-hover:underline group-hover:underline-offset-4 sm:text-2xl">
														{post.data.title}
													</h2>
													<p class="mt-2 text-fg-muted text-pretty">{post.data.description}</p>
													{post.data.tags.length > 0 && (
														<ul class="mt-4 flex flex-wrap gap-1.5 font-mono text-2xs" role="list">
															{post.data.tags.map((t) => (
																<li class="rounded-sm border border-border px-1.5 py-0.5 text-fg-muted">
																	#{t}
																</li>
															))}
														</ul>
													)}
												</div>
												<span class="font-mono text-2xs tracking-[0.18em] text-fg-subtle uppercase transition-colors group-hover:text-fg sm:self-center">
													Read →
												</span>
											</a>
										</li>
									))}
								</ul>
							</div>
						</div>
					))}
				</div>
			</section>
		) : (
			<section class="border-b border-border">
				<div class="mx-auto w-full max-w-page px-6 py-24 sm:px-8 sm:py-32">
					<div class="mx-auto max-w-xl text-center">
						<p class="font-mono text-2xs tracking-[0.18em] text-fg-subtle uppercase">
							Empty for now
						</p>
						<h2 class="mt-4 text-2xl font-medium tracking-tight text-balance sm:text-3xl">
							The first post lands soon.
						</h2>
						<p class="mt-4 text-fg-muted text-pretty">
							Roga Digital just relaunched. The writing follows. Expect project write-ups, opinions
							on tooling, and pragmatic takes on what AI is changing about how business software
							gets built.
						</p>
						<div class="mt-8">
							<a
								href="/rss.xml"
								class="inline-flex items-center gap-2 font-mono text-2xs tracking-[0.18em] text-fg-muted uppercase transition-colors hover:text-fg"
							>
								<svg
									width="12"
									height="12"
									viewBox="0 0 16 16"
									fill="none"
									stroke="currentColor"
									stroke-width="1.5"
									stroke-linecap="round"
									stroke-linejoin="round"
									aria-hidden="true"
								>
									<path d="M3 11a3 3 0 0 1 3 3M3 6a8 8 0 0 1 8 8" />
									<circle cx="3.5" cy="13.5" r="0.5" fill="currentColor" />
								</svg>
								Subscribe via RSS
							</a>
						</div>
					</div>
				</div>
			</section>
		)
	}

	<!-- End CTA -->
	<section class="bg-bg-soft">
		<div class="mx-auto w-full max-w-page px-6 py-16 sm:px-8 sm:py-20">
			<div class="grid gap-6 lg:grid-cols-12 lg:items-center">
				<div class="lg:col-span-8">
					<p class="font-mono text-2xs tracking-[0.18em] text-fg-subtle uppercase">
						More from Roga Digital
					</p>
					<h2 class="mt-3 text-2xl font-medium tracking-tight text-balance sm:text-3xl">
						See the work, or get in touch.
					</h2>
				</div>
				<div class="flex flex-wrap items-center gap-3 lg:col-span-4 lg:justify-end">
					<a
						href="/work"
						class="inline-flex items-center gap-2 rounded-md border border-border-strong px-4 py-2.5 text-sm text-fg transition-colors hover:border-fg-subtle"
					>
						Selected work
					</a>
					<a
						href="/contact"
						class="inline-flex items-center gap-2 rounded-md bg-fg px-4 py-2.5 text-sm font-medium text-bg transition-opacity hover:opacity-90"
					>
						Book a call
					</a>
				</div>
			</div>
		</div>
	</section>
</Base>
