{
	"$schema": "https://openapi.vercel.sh/vercel.json",
	"framework": "astro",
	"buildCommand": "npx --yes pnpm@11.9.0 run build",
	"outputDirectory": "dist",
	"installCommand": "npx --yes pnpm@11.9.0 install --frozen-lockfile",
	"redirects": [
		{
			"source": "/work/techcentral-telus",
			"destination": "/work/telus-techcentral",
			"permanent": true
		},
		{
			"source": "/work/project-summit-telus",
			"destination": "/work/telus-summit",
			"permanent": true
		},
		{
			"source": "/work/tc-tools",
			"destination": "/work/telus-tc-tools",
			"permanent": true
		},
		{
			"source": "/work/lot-logistics-web-application",
			"destination": "/work/carevo-logistics",
			"permanent": true
		}
	]
}
