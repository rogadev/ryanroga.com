{
	"name": "ryanroga-com",
	"type": "module",
	"version": "2.0.2",
	"private": true,
	"packageManager": "pnpm@10.33.0",
	"engines": {
		"node": ">=24.0.0"
	},
	"scripts": {
		"dev": "astro dev",
		"devo": "astro dev --open",
		"build": "astro build",
		"preview": "astro preview",
		"check": "astro check",
		"astro": "astro",
		"lint": "oxlint && eslint .",
		"lint:fast": "oxlint",
		"lint:fix": "oxlint --fix && eslint --fix .",
		"format": "prettier --write . --log-level warn",
		"format:check": "prettier --check . --log-level warn",
		"fix": "pnpm format && pnpm format:check && pnpm lint:fix && pnpm lint",
		"ready": "pnpm fix && pnpm check"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"sharp"
		],
		"overrides": {
			"yaml@>=2.0.0 <2.8.3": ">=2.8.3",
			"fast-xml-builder@<=1.1.6": ">=1.1.7",
			"fast-xml-builder@=1.1.5": ">=1.1.6",
			"fast-uri@<=3.1.0": ">=3.1.1",
			"fast-uri@<=3.1.1": ">=3.1.2",
			"svelte@<=5.55.6": ">=5.55.7",
			"svelte@>=5.46.0 <=5.55.6": ">=5.55.7",
			"svelte@>=5.51.5 <=5.55.6": ">=5.55.7",
			"devalue@>=5.6.3 <=5.8.0": ">=5.8.1",
			"brace-expansion@>=5.0.0 <5.0.6": ">=5.0.6"
		}
	},
	"dependencies": {
		"@astrojs/mdx": "^6.0.2",
		"@astrojs/rss": "^4.0.18",
		"@astrojs/sitemap": "^3.7.3",
		"@astrojs/svelte": "^8.1.2",
		"@fontsource-variable/geist": "^5.2.9",
		"@fontsource-variable/geist-mono": "^5.2.8",
		"@fontsource/geist-mono": "^5.2.8",
		"@fontsource/geist-sans": "^5.2.5",
		"@shikijs/transformers": "^4.2.0",
		"@tailwindcss/vite": "^4.3.0",
		"astro": "^6.4.4",
		"satori": "^0.26.0",
		"sharp": "^0.34.5",
		"svelte": "^5.56.1",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.9",
		"astro-eslint-parser": "^1.4.0",
		"eslint": "^10.4.1",
		"eslint-plugin-astro": "^1.7.0",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"oxlint": "^1.68.0",
		"prettier": "^3.8.3",
		"prettier-plugin-astro": "^0.14.1",
		"prettier-plugin-svelte": "^4.1.0",
		"svelte-eslint-parser": "^1.7.1",
		"typescript-eslint": "^8.60.1"
	}
}
